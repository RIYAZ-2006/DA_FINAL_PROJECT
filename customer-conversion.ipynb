    "    print(\"\\nConversion Rate by Referral Source:\")\n",
    "    print(referral_conv)\n",
    "    \n",
    "    # Average purchase amount by referral source\n",
    "    referral_purchase = df[df['converted'] == 1].groupby('referral_source')['purchase_amount'].mean().sort_values(ascending=False)\n",
    "    print(\"\\nAverage Purchase Amount by Referral Source:\")\n",
    "    print(referral_purchase)\n",
    "    \n",
    "    # Correlation analysis\n",
    "    plt.figure(figsize=(12, 10))\n",
    "    corr = df.select_dtypes(include=['float64', 'int64']).corr()\n",
    "    sns.heatmap(corr, annot=True, cmap='coolwarm', fmt='.2f')\n",
    "    plt.title('Correlation Matrix')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    # Visualize relationships\n",
    "    plt.figure(figsize=(20, 15))\n",
    "    \n",
    "    plt.subplot(2, 3, 1)\n",
    "    sns.boxplot(x='converted', y='time_spent_sec', data=df)\n",
    "    plt.title('Time Spent vs Conversion')\n",
    "    \n",
    "    plt.subplot(2, 3, 2)\n",
    "    sns.boxplot(x='converted', y='product_page_views', data=df)\n",
    "    plt.title('Product Page Views vs Conversion')\n",
    "    \n",
    "    plt.subplot(2, 3, 3)\n",
    "    sns.boxplot(x='converted', y='add_to_cart_actions', data=df)\n",
    "    plt.title('Add to Cart Actions vs Conversion')\n",
    "    \n",
    "    plt.subplot(2, 3, 4)\n",
    "    sns.countplot(x='device', hue='converted', data=df)\n",
    "    plt.title('Conversion by Device')\n",
    "    \n",
    "    plt.subplot(2, 3, 5)\n",
    "    sns.countplot(x='referral_source', hue='converted', data=df)\n",
    "    plt.title('Conversion by Referral Source')\n",
    "    plt.xticks(rotation=45)\n",
    "    \n",
    "    plt.subplot(2, 3, 6)\n",
    "    sns.scatterplot(x='time_spent_sec', y='purchase_amount', data=df[df['converted'] == 1])\n",
    "    plt.title('Time Spent vs Purchase Amount (Converted Only)')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Run EDA\n",
    "explore_clickstream_data(clickstream_data)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
